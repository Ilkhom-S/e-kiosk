<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>frmHardwareWindow</class>
    <widget class="QWidget" name="frmHardwareWindow">
        <property name="windowTitle">
            <string notr="true">#hardware_setup</string>
        </property>
        <property name="styleSheet">
            <string notr="true">
                QWidget#frmHardwareWindow { background-color: transparent; }

                /* Secondary action buttons (Detect, Add, Ok, Cancel) */
                QPushButton {
                background-color: #D4D4D4; /* Neutral grey background */
                color: #172B4D; /* Deep navy text for outdoor readability */
                border-radius: 20px;
                font-family: "Segoe UI";
                font-size: 24px;
                font-weight: 700;
                padding: 10px;
                min-width: 160px;
                text-transform: uppercase;
                }
                QPushButton:pressed {
                background-color: #A6A6A6; /* Darker grey on press */
                color: #172B4D;
                }
                QPushButton:disabled {
                background-color: #F0F0F0;
                color: #8E8E93;
                }

                /* Cancel button variant */
                QPushButton#btnCancel {
                background-color: transparent;
                border: 2px solid #8E8E93;
                color: #8E8E93;
                }
                QPushButton#btnCancel:pressed {
                background-color: #8E8E93;
                color: #FFFFFF;
                }

                /* List styling for touchscreen */
                QListWidget {
                border: none;
                color: #172B4D;
                font-family: "Segoe UI";
                font-size: 24px;
                font-weight: 700;
                }
                QListWidget::item {
                height: 60px; /* Larger touch target */
                background-color: #D4D4D4; /* Neutral grey background */
                border-bottom: 1px solid #A6A6A6; /* Divider line between items */
                padding-left: 12px;
                }
                QListWidget::item:selected {
                background-color: #FA5300; /* Orange highlight */
                color: #FFFFFF; /* White text for contrast */
                }
            </string>
        </property>

        <layout class="QVBoxLayout" name="mainLayout">
            <item>
                <widget class="QStackedWidget" name="stackedWidget">
                    <property name="currentIndex">
                        <number>0</number>
                    </property>

                    <!-- All Devices Page -->
                    <widget class="QWidget" name="wAllDevicesPage">
                        <layout class="QVBoxLayout" name="allDevicesLayout">
                            <item>
                                <layout class="QHBoxLayout" name="buttonRow">
                                    <item>
                                        <spacer name="hsLeft">
                                            <property name="orientation">
                                                <enum>Qt::Horizontal</enum>
                                            </property>
                                        </spacer>
                                    </item>
                                    <item>
                                        <widget class="QPushButton" name="btnDetect">
                                            <property name="text">
                                                <string>#detect</string>
                                            </property>
                                        </widget>
                                    </item>
                                    <item>
                                        <widget class="QPushButton" name="btnAdd">
                                            <property name="text">
                                                <string>#add_slot</string>
                                            </property>
                                        </widget>
                                    </item>
                                    <item>
                                        <spacer name="hsRight">
                                            <property name="orientation">
                                                <enum>Qt::Horizontal</enum>
                                            </property>
                                        </spacer>
                                    </item>
                                </layout>
                            </item>
                            <item>
                                <widget class="QScrollArea" name="scrollArea">
                                    <property name="frameShape">
                                        <enum>QFrame::NoFrame</enum>
                                    </property>
                                    <property name="widgetResizable">
                                        <bool>true</bool>
                                    </property>
                                    <widget class="QWidget" name="scrollAreaWidgetContents">
                                        <layout class="QVBoxLayout" name="scrollLayout">
                                            <item>
                                                <widget class="QWidget" name="slotsWidget"
                                                    native="true" />
                                            </item>
                                        </layout>
                                    </widget>
                                </widget>
                            </item>
                        </layout>
                    </widget>

                    <!-- Select Type Page -->
                    <widget class="QWidget" name="wSelectTypePage">
                        <layout class="QVBoxLayout" name="selectTypeLayout">
                            <item>
                                <widget class="QListWidget" name="lwTypes">
                                    <item>
                                        <property name="text">
                                            <string notr="true">Купюроприёмник</string>
                                        </property>
                                    </item>
                                    <item>
                                        <property name="text">
                                            <string notr="true">Принтер</string>
                                        </property>
                                    </item>
                                    <item>
                                        <property name="text">
                                            <string notr="true">Фискальный регистратор</string>
                                        </property>
                                    </item>
                                    <item>
                                        <property name="text">
                                            <string notr="true">Сторожевой таймер</string>
                                        </property>
                                    </item>
                                    <item>
                                        <property name="text">
                                            <string notr="true">Модем</string>
                                        </property>
                                    </item>
                                </widget>
                            </item>
                            <item>
                                <layout class="QHBoxLayout" name="okCancelRow">
                                    <item>
                                        <widget class="QPushButton" name="btnOk">
                                            <property name="text">
                                                <string>#ok</string>
                                            </property>
                                        </widget>
                                    </item>
                                    <item>
                                        <widget class="QPushButton" name="btnCancel">
                                            <property name="text">
                                                <string>#cancel</string>
                                            </property>
                                        </widget>
                                    </item>
                                </layout>
                            </item>
                        </layout>
                    </widget>
                </widget>
            </item>
        </layout>
    </widget>
    <resources>
        <include location="../Resources/Resources.qrc" />
    </resources>
    <connections />
</ui>