  <property name="styleSheet">
   <string notr="true">
                QWidget#WizardFrame { background-color: #0A0A0B; }
                QWidget#wPage, QWidget#wButtonBar { background-color: #1C1C1E; border-radius: 45px;
                }

                QLabel#lbStageName {
                color: #FFFFFF;
                font-family: &quot;Segoe UI&quot;;
                font-size: 42px;
                font-weight: 900;
                text-transform: uppercase;
                }
                QLabel#lbStageHowto {
                color: #8E8E93;
                font-family: &quot;Segoe UI&quot;;
                font-size: 22px;
                font-weight: 600;
                }

                QPushButton {
                background-color: #FA5300;
                color: #FFFFFF;
                border-radius: 25px;
                font-size: 28px;
                font-weight: 700;
                padding: 20px;
                min-width: 200px;
                }

                /* Back Button */
                QPushButton#btnBack {
                background-color: transparent;
                border: 3px solid #FA5300;
                color: #FA5300;
                }
                QPushButton#btnBack:pressed {
                background-color: #FF7A3D; /* Orange fill on press */
                color: #FFFFFF; /* Switch text to white */
                }

                /* Forward Button */
                QPushButton#btnForward {
                background-color: #FA5300;
                color: #FFFFFF;
                }
                QPushButton#btnForward:pressed {
                background-color: #FF7A3D; /* Darker orange on press */
                }

                /* Exit Button */
                QPushButton#btnExit {
                background-color: #FF3B30; /* Industrial Critical Red */
                color: #FFFFFF;
                border-radius: 40px; /* Perfect Circle */
                font-size: 42px;
                font-weight: 900;
                border: none;
                }
                QPushButton#btnExit:pressed {
                background-color: #8B0000;
                }
            </string>
  </property>
