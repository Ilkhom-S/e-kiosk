<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
    <class>WelcomeWizardPage</class>
    <widget class="QWidget" name="WelcomeWizardPage">
        <property name="styleSheet">
            <string notr="true">
                QWidget#WelcomeWizardPage { background-color: transparent; }

                QLabel#lbLogo {
                padding: 20px;
                }

                QPushButton#btnSetup {
                background-color: #FA5300;
                color: #FFFFFF;
                border-radius: 25px;
                font-family: "Segoe UI";
                font-size: 32px; /* Balanced for 17" 1280x1024 */
                font-weight: 900;
                text-transform: uppercase;
                }

                QPushButton#btnSetup:pressed {
                background-color: #FF7A3D;
                }
            </string>
        </property>
        <layout class="QVBoxLayout" name="mainLayout">
            <!-- Top Spacer -->
            <item>
                <spacer name="vsTop">
                    <property name="orientation">
                        <enum>Qt::Vertical</enum>
                    </property>
                </spacer>
            </item>

            <!-- Center Layout -->
            <item>
                <layout class="QHBoxLayout" name="centerLayout">
                    <item>
                        <spacer name="hsLeft">
                            <property name="orientation">
                                <enum>Qt::Horizontal</enum>
                            </property>
                        </spacer>
                    </item>
                    <item>
                        <widget class="QFrame" name="wizardFrame">
                            <property name="minimumSize">
                                <size>
                                    <width>520</width>
                                    <height>350</height>
                                </size>
                            </property>
                            <property name="maximumSize">
                                <size>
                                    <width>520</width>
                                    <height>350</height>
                                </size>
                            </property>
                            <layout class="QVBoxLayout" name="frameLayout">
                                <property name="spacing">
                                    <number>30</number>
                                </property>

                                <!-- Logo -->
                                <item>
                                    <widget class="QLabel" name="lbLogo">
                                        <property name="minimumSize">
                                            <size>
                                                <width>400</width>
                                                <height>150</height>
                                            </size>
                                        </property>
                                        <property name="pixmap">
                                            <pixmap resource="../../GUI/Resources/Resources.qrc">
                                                :/Images/humo_logo_midnight.svg</pixmap>
                                        </property>
                                        <property name="scaledContents">
                                            <bool>true</bool>
                                        </property>
                                        <property name="alignment">
                                            <set>Qt::AlignCenter</set>
                                        </property>
                                    </widget>
                                </item>

                                <!-- Run Setup Button -->
                                <item>
                                    <widget class="QPushButton" name="btnSetup">
                                        <property name="minimumSize">
                                            <size>
                                                <width>400</width>
                                                <height>100</height>
                                            </size>
                                        </property>
                                        <property name="text">
                                            <string>#run_setup</string>
                                        </property>
                                    </widget>
                                </item>
                            </layout>
                        </widget>
                    </item>
                    <item>
                        <spacer name="hsRight">
                            <property name="orientation">
                                <enum>Qt::Horizontal</enum>
                            </property>
                        </spacer>
                    </item>
                </layout>
            </item>

            <!-- Bottom Spacer -->
            <item>
                <spacer name="vsBottom">
                    <property name="orientation">
                        <enum>Qt::Vertical</enum>
                    </property>
                </spacer>
            </item>
        </layout>
    </widget>
    <resources>
        <include location="../../GUI/Resources/Resources.qrc" />
    </resources>
    <connections />
</ui>